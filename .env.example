# Copy this file to .env.local and fill in the values for your environment.

# Application Insights connection string — from Azure portal:
# App Insights resource → Properties → Connection String
TELEMETRY_CONNECTION_STRING="InstrumentationKey=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Smoke test — path to the chat-with-agent bundle (used by test/smoke-test-caller.mjs)
SMOKE_BUNDLE_PATH="C:\path\to\chat-with-agent.bundle.js"

# Smoke test — Power Platform DirectLine token endpoint for the target bot
SMOKE_TOKEN_ENDPOINT="https://<env-id>.environment.api.powerplatform.com/powervirtualagents/botsbyschema/<bot-schema>/directline/token?api-version=2022-03-01-preview"

# Smoke test — default phone number and utterance for npm test (no flags needed when set)
SMOKE_PHONE="+12125551234"
SMOKE_UTTERANCE="how do I return an item"
